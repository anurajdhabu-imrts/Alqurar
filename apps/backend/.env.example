# Copy to .env and fill in real values. Do NOT commit your real .env.

# Application
APP_NAME="Al Qarar"
APP_VERSION="1.0.0"
DEBUG=true

# Database (async URL — use asyncpg driver; normalised to psycopg2 internally)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/alqrar

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — generate with: openssl rand -hex 32
JWT_SECRET_KEY=change_this_to_a_random_64_char_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SuperAdmin — created on first boot via seed
SUPERADMIN_EMAIL=admin@example.com
SUPERADMIN_PASSWORD=ChangeMe@123
SUPERADMIN_NAME="Super Admin"

# CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Public base URL of the frontend — used to build client portal upload links.
# Local dev: http://localhost:5173 — Production: https://your-production-domain.com
FRONTEND_URL=http://localhost:5173

# Cloudflare R2 (optional object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Google Drive (optional document storage). Path to the service-account JSON key.
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=service-account.json

# Anthropic API key for AI document analysis — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Client portal OTP + session
OTP_TTL_MINUTES=10
PORTAL_SESSION_DAYS=7

# SMTP for sending OTP emails (REQUIRED for the client portal OTP to work).
# The OTP is delivered only by email — it is never shown on screen or returned by the API.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=no-reply@your-domain.com
SMTP_USE_TLS=true
